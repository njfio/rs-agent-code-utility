{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "query_code.v1",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "pattern": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "prefilter": { "type": "string", "minLength": 1 },
        "context": { "type": "integer", "minimum": 0, "default": 3 }
      },
      "required": ["path", "pattern", "language"],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema_version": { "const": "1" },
        "tool": { "const": "query_code" },
        "command": { "const": "query" },
        "path": { "type": "string" },
        "report": {}
      },
      "required": ["schema_version", "tool", "command", "path", "report"],
      "additionalProperties": false
    }
  },
  "required": ["input", "output"],
  "additionalProperties": false
}
