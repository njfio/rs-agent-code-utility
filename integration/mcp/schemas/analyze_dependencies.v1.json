{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "analyze_dependencies.v1",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "includeDev": { "type": "boolean", "default": false },
        "vulnerabilities": { "type": "boolean", "default": false },
        "licenses": { "type": "boolean", "default": false },
        "outdated": { "type": "boolean", "default": false },
        "graph": { "type": "boolean", "default": false }
      },
      "required": ["path"],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema_version": { "const": "1" },
        "tool": { "const": "analyze_dependencies" },
        "command": { "const": "dependencies" },
        "path": { "type": "string" },
        "report": {}
      },
      "required": ["schema_version", "tool", "command", "path", "report"],
      "additionalProperties": false
    }
  },
  "required": ["input", "output"],
  "additionalProperties": false
}
