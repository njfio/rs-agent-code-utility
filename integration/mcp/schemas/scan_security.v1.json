{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "scan_security.v1",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "minSeverity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"], "default": "low" },
        "depth": { "type": "string", "enum": ["basic", "deep", "full"], "default": "full" },
        "includeTests": { "type": "boolean", "default": false },
        "includeExamples": { "type": "boolean", "default": false },
        "includeNonCode": { "type": "boolean", "default": false },
        "minConfidence": { "type": "string", "enum": ["low", "medium", "high"], "default": "low" },
        "enableSecurity": { "type": "boolean", "default": false },
        "noAiFilter": { "type": "boolean", "default": false },
        "filterMode": { "type": "string", "enum": ["strict", "balanced", "permissive"], "default": "balanced" },
        "maxFileKb": { "type": "integer", "minimum": 1, "default": 1024 }
      },
      "required": ["path"],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema_version": { "const": "1" },
        "tool": { "const": "scan_security" },
        "command": { "const": "security" },
        "path": { "type": "string" },
        "report": {}
      },
      "required": ["schema_version", "tool", "command", "path", "report"],
      "additionalProperties": false
    }
  },
  "required": ["input", "output"],
  "additionalProperties": false
}
