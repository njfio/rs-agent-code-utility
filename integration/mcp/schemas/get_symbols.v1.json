    "input": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 }
      },
      "required": ["path"],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "schema_version": { "const": "1" },
        "tool": { "const": "get_symbols" },
        "command": { "const": "symbols" },
        "path": { "type": "string" },
        "report": {}
      },
      "required": ["schema_version", "tool", "command", "path", "report"],
      "additionalProperties": false
    }
  },
  "required": ["input", "output"],
  "additionalProperties": false
}
