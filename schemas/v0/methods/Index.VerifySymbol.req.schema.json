      "type": "string",
      "enum": ["fn", "struct", "enum", "type", "trait", "const", "static", "impl", "method", "class", "interface", "module", "heading"]
    },
    "lang": { "type": "string" },
    "file": { "type": "string" },
    "content_version": { "type": "string" }
  },
  "required": ["name"],
  "additionalProperties": false
}
