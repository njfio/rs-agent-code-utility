{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rts.local/schemas/v0/methods/Index.VerifySymbol.req.schema.json",
  "title": "Index.VerifySymbol request params",
  "description": "verify-v0 P1.U1, capability `verify_symbol`. Answers \"does this symbol exist?\" — returns exists/resolution plus ranked near-miss candidates on a miss.",
