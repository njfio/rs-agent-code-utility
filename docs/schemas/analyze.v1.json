{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalyzeResultV1",
  "type": "object",
  "required": [
    "root_path",
    "total_files",
    "parsed_files",
    "error_files",
    "total_lines",
    "languages",
    "files",
    "config"
  ],
  "properties": {
    "root_path": { "type": "string" },
    "total_files": { "type": "integer", "minimum": 0 },
    "parsed_files": { "type": "integer", "minimum": 0 },
    "error_files": { "type": "integer", "minimum": 0 },
    "total_lines": { "type": "integer", "minimum": 0 },
    "languages": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path", "language", "size", "lines",
          "parsed_successfully", "parse_errors", "symbols", "security_vulnerabilities"
        ],
        "properties": {
          "path": { "type": "string" },
          "language": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "lines": { "type": "integer", "minimum": 0 },
          "parsed_successfully": { "type": "boolean" },
          "parse_errors": { "type": "array", "items": { "type": "string" } },
          "symbols": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name", "kind", "start_line", "end_line",
                "start_column", "end_column", "visibility"
              ],
              "properties": {
                "name": { "type": "string" },
                "kind": { "type": "string" },
                "start_line": { "type": "integer", "minimum": 1 },
                "end_line": { "type": "integer", "minimum": 1 },
                "start_column": { "type": "integer", "minimum": 0 },
                "end_column": { "type": "integer", "minimum": 0 },
                "visibility": { "type": "string" },
                "documentation": { "type": ["string", "null"] }
              }
            }
          },
          "security_vulnerabilities": { "type": "array" }
        }
      }
    },
    "config": { "type": "object" },
    "semantic_graph": {
      "type": "object",
      "required": ["nodes", "edges", "statistics"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "node_type", "name", "file_path", "line_number", "metadata", "properties"],
            "properties": {
              "id": { "type": "string" },
              "node_type": { "type": "string" },
              "name": { "type": "string" },
              "file_path": { "type": "string" },
              "line_number": { "type": "integer", "minimum": 0 },
              "metadata": { "type": "object", "additionalProperties": { "type": "string" } },
              "properties": {
                "type": "object",
                "required": ["complexity", "importance", "in_degree", "out_degree", "tags"],
                "properties": {
                  "complexity": { "type": "number" },
                  "importance": { "type": "number" },
                  "in_degree": { "type": "integer", "minimum": 0 },
                  "out_degree": { "type": "integer", "minimum": 0 },
                  "tags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "relationship", "weight"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "relationship": { "type": "string" },
              "weight": { "type": "number" },
              "context": { "type": ["string", "null"] }
            }
          }
        },
        "statistics": {
          "type": "object",
          "required": [
            "total_nodes",
            "total_edges",
            "node_type_distribution",
            "relationship_type_distribution"
          ],
          "properties": {
            "total_nodes": { "type": "integer", "minimum": 0 },
            "total_edges": { "type": "integer", "minimum": 0 },
            "node_type_distribution": { "type": "object" },
            "relationship_type_distribution": { "type": "object" }
          }
        }
      }
    }
  }
}
